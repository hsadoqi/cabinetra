{
  "extends": "@cabinetra/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@cabinetra/ui": [
        "./src/index.ts"
      ],
      "@cabinetra/ui/*": [
        "./src/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
