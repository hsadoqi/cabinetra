{
    "name": "@cabinetra/ui-hooks",
    "version": "0.1.0",
    "private": true,
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/*"
    },
    "scripts": {
        "lint": "eslint . --max-warnings 0",
        "check-types": "tsc --noEmit",
        "test": "vitest run",
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch",
        "clean": "rm -rf .turbo .dist node_modules dist && pnpm install"
    },
    "devDependencies": {
        "@cabinetra/eslint-config": "workspace:*",
        "@cabinetra/typescript-config": "workspace:*",
        "@types/node": "^22.15.3",
        "@types/react": "19.2.2",
        "eslint": "^9.39.1",
        "typescript": "5.9.2",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "react": "^19.2.0"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    }
}