{
  "name": "@cabinetra/ui",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./components": "./src/components/index.ts",
    "./hooks/*": "./src/hooks/*",
    "./lib/*": "./src/lib/*",
    "./primitives/*": "./src/primitives/*.tsx",
    "./primitives": "./src/primitives/index.ts",
    "./styles.css": "./src/styles/globals.css"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "sync:exports": "node ./scripts/sync-exports.mjs",
    "shadcn:add": "node ./scripts/shadcn-add.mjs",
    "check-types": "tsc --noEmit",
    "build": "node ./scripts/sync-exports.mjs && tsc -p tsconfig.json",
    "dev": "node ./scripts/sync-exports.mjs && tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@cabinetra/eslint-config": "workspace:*",
    "@cabinetra/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "label": "^0.2.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.0"
  }
}
