{
  "name": "cabinetra",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "shadcn:add": "pnpm -F @cabinetra/ui shadcn:add"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "prettier": "^3.8.3",
    "turbo": "latest",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0"
}
