{
  "extends": "@cabinetra/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "paths": {
      "@cabinetra/ui": ["./src/index.ts"],
      "@cabinetra/ui/*": ["./src/*"]
    },
    "rootDir": "src",
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
