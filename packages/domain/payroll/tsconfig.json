{
    "extends": "@cabinetra/typescript-config/react-library.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@cabinetra/domain-payroll": [
                "./src/index.ts"
            ],
            "@cabinetra/domain-payroll/*": [
                "./src/*"
            ]
        },
        "strictNullChecks": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
