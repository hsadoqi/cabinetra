{
  "extends": "@cabinetra/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@cabinetra/ui-components": [
        "./src/index.ts"
      ],
      "@cabinetra/ui-components/*": [
        "./src/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}